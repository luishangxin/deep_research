{
    "mcp_servers": [
        {
            "name": "filesystem",
            "description": "Local filesystem operations via MCP",
            "enabled": false,
            "transport": "stdio",
            "command": "npx",
            "args": [
                "-y",
                "@modelcontextprotocol/server-filesystem",
                "/tmp/sandbox"
            ]
        },
        {
            "name": "brave-search",
            "description": "Web search via Brave Search MCP",
            "enabled": false,
            "transport": "stdio",
            "command": "npx",
            "args": [
                "-y",
                "@modelcontextprotocol/server-brave-search"
            ],
            "env": {
                "BRAVE_API_KEY": "$BRAVE_API_KEY"
            }
        }
    ],
    "skills": [],
    "extra_prompts": []
}